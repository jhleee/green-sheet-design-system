{
  "name": "green-sheet-design-system",
  "version": "0.1.0",
  "description": "데이터 그리드 중심 웹 애플리케이션을 위한 Tailwind v4 디자인 시스템 — 25 tokens, 종이·잉크 테마, 다크 모드, 컴포넌트 + 앱 레이아웃",
  "keywords": [
    "design-system",
    "tailwindcss",
    "tailwind-v4",
    "design-tokens",
    "data-table",
    "data-grid",
    "app-shell",
    "korean"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "theme.css",
  "style": "theme.css",
  "exports": {
    ".": "./theme.css",
    "./theme.css": "./theme.css",
    "./fonts.css": "./fonts.css",
    "./dist/green-sheet.css": "./dist/green-sheet.css"
  },
  "files": [
    "theme.css",
    "fonts.css",
    "dist/green-sheet.css",
    "llms.txt",
    "foundations/",
    "components/",
    "layouts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tailwindcss -i theme.css -o dist/green-sheet.css",
    "dev": "tailwindcss -i theme.css -o dist/green-sheet.css --watch",
    "preview": "npx --yes http-server -p 8899 -c-1",
    "test": "node tests/e2e/check-refs.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  }
}
